{
  "compilerOptions": {
    "noErrorTruncation": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/collection/*": [
        "./src/_payload/collections/*"
      ],
      "@/blocks/*": [
        "./src/_payload/blocks/*"
      ],
      "@/globals/*": [
        "./src/_payload/globals/*"
      ],
      "@/*": [
        "./src/*",
        "./@types/*",
        "./src/_payload/*"
      ],
      "@payload-config": [
        "./src/_payload/payload.config.ts"
      ],
      "www/*": [
        "./src/app/fe/(Content)/*",
        "./src/app/(frontend)/(Content)/*",
      ]
    },
    "target": "ES2022",
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "@types/**/*.ts",
    "./next/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}